# ─── MongoDB Compass (local) ───────────────────────────────
# Make sure MongoDB service is running on your machine first.
# Open MongoDB Compass and connect to: mongodb://127.0.0.1:27017
# The database "budgetwise" will be created automatically on first run.
MONGO_URI=mongodb://localhost:27017/

# ─── JWT Secret ────────────────────────────────────────────
# Use any long random string. Keep it secret!
JWT_SECRET=budgetwise_super_secret_key_change_in_production_2026

# ─── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Client URL (for CORS) ─────────────────────────────────
CLIENT_URL=http://localhost:5173
